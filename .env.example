# Base URL of the training-chatbot-backend (no trailing slash).
# Used by the Next.js API proxy routes (server-side only, never exposed to the browser).
BACKEND_URL=https://training-chatbot-backend.vercel.app
# API key for authenticating with the backend (server-side only, never exposed to browser)
BACKEND_API_KEY=your-backend-api-key
# Upstash Redis — session persistence (get from https://console.upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

